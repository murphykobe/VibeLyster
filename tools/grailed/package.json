{
  "name": "@vibelyster/grailed-cli",
  "version": "0.1.0",
  "description": "CLI for Grailed's internal API — list, draft, publish, and manage listings",
  "type": "module",
  "bin": {
    "grailed": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "esbuild cli.js --bundle --platform=node --format=esm --minify --outfile=dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "keywords": [
    "grailed",
    "reselling",
    "cli",
    "listing"
  ],
  "license": "MIT",
  "private": false
}
