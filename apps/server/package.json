{
  "name": "@vibelyster/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3001",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3001",
    "dev:mock": "MOCK_MODE=1 next dev --hostname 127.0.0.1 --port 3001",
    "dev:mock:lan": "MOCK_MODE=1 next dev --hostname 0.0.0.0 --port 3001",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "publish:smoke": "node ./scripts/live-publish-smoke.mjs",
    "vercel:pull:preview": "npx vercel pull --yes --environment=preview",
    "vercel:pull:production": "npx vercel pull --yes --environment=production",
    "vercel:deploy:preview": "npx vercel --yes",
    "vercel:deploy:production": "npx vercel --prod --yes",
    "vercel:env:ls": "npx vercel env ls"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.0",
    "@clerk/nextjs": "^6.0.0",
    "@neondatabase/serverless": "^0.10.0",
    "@vercel/blob": "^0.27.0",
    "ai": "^4.0.0",
    "impit": "^0.13.0",
    "next": "^15.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^16.4.7",
    "typescript": "^5.8.0",
    "vitest": "^2.1.9"
  }
}
