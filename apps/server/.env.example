# Database (from Vercel + Neon integration)
DATABASE_URL=postgresql://user:pass@host/dbname

# Clerk (from Vercel + Clerk integration)
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Vercel AI Gateway (auto-injected on Vercel, run `vercel env pull` locally)
VERCEL_OIDC_TOKEN=...

# Soniox speech-to-text (https://soniox.com)
SONIOX_API_KEY=...

# Token encryption (generate: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=...

# Vercel Blob (auto-injected via Vercel integration)
BLOB_READ_WRITE_TOKEN=...
