# Clerk (copy NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY from server .env.local)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...

# Backend URL (local dev)
EXPO_PUBLIC_API_URL=http://localhost:3001

# Optional mock mode for local E2E
# EXPO_PUBLIC_MOCK_MODE=1
# EXPO_PUBLIC_MOCK_USER_ID=ios-dev-1

# Production/Staging example:
# EXPO_PUBLIC_API_URL=https://<your-vercel-server-domain>
# EXPO_PUBLIC_MOCK_MODE=0
