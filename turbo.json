{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "AI_GATEWAY_API_KEY",
        "ALLOWED_ORIGINS",
        "CLERK_SECRET_KEY",
        "DATABASE_URL",
        "MOCK_MODE",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "SONIOX_API_KEY",
        "TOKEN_ENCRYPTION_KEY",
        "VERCEL_OIDC_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "cache": false
    }
  }
}
